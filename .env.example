# Copy to .env (gitignored) and fill in. See docs/data-adapter-api.md.

# YouTube Data API v3 key — powers the api_mcp adapter (Stage 1 verified metrics).
# Google Cloud Console → enable "YouTube Data API v3" → Credentials → API key.
YOUTUBE_API_KEY=

# Optional — Social Blade API, only if true 30-day sub velocity is needed.
SOCIALBLADE_API_KEY=

# STATE 13 voice (tools/synthesize.py) — ElevenLabs TTS. Works locally now, or
# in-sandbox once api.elevenlabs.io is allowlisted in the network policy.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_multilingual_v2
